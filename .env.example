# Copy to .env (which is gitignored) and fill in real values.

# ─── API runtime ──────────────────────────────────────────────────────────────
PORT=3001
COMMONS_BASE_URL=http://localhost:3001

# ─── Database (used after Postgres migration; pglite in tests) ────────────────
# Local dev (use a docker postgres or Fly Postgres connection string):
# DATABASE_URL=postgresql://user:pass@localhost:5432/commons

# ─── Verifier — real LLM judges (optional; falls back to heuristic if absent) ──
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Stage 2 sandbox (optional) ───────────────────────────────────────────────
# E2B_API_KEY=e2b_...

# ─── Observability (optional) ─────────────────────────────────────────────────
# AXIOM_TOKEN=xaat-...
# AXIOM_DATASET=commons

# ─── Web pages ────────────────────────────────────────────────────────────────
# Public base URL used in sitemap.xml and canonical link tags
PUBLIC_BASE_URL=http://localhost:3001
